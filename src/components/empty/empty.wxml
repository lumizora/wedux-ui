<view class="w-empty w-empty--{{size}}">
  <view class="w-empty__image" style="{{_imageStyle}}">
    <slot name="image">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" class="w-empty__svg">
        <rect
          x="30"
          y="80"
          width="140"
          height="90"
          rx="8"
          ry="8"
          fill="none"
          stroke="currentColor"
          stroke-width="8"
        />
        <path
          d="M30 120 L65 120 Q72 120 76 113 L84 98 Q88 91 96 91 L104 91 Q112 91 116 98 L124 113 Q128 120 135 120 L170 120"
          fill="none"
          stroke="currentColor"
          stroke-width="8"
          stroke-linejoin="round"
        />
        <path
          d="M70 80 L80 55 Q84 47 92 47 L108 47 Q116 47 120 55 L130 80"
          fill="none"
          stroke="currentColor"
          stroke-width="8"
          stroke-linejoin="round"
        />
      </svg>
    </slot>
  </view>
  <view class="w-empty__title"><text>{{title}}</text></view>
  <view wx:if="{{description}}" class="w-empty__description"><text>{{description}}</text></view>
  <view class="w-empty__extra">
    <slot name="extra"></slot>
  </view>
</view>
