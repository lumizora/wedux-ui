<view class="page">
  <w-theme-provider theme="{{theme}}" style="height: 100%">
    <w-layout>
      <w-layout-header position="static">
        <w-navigation-bar title="我的" back="{{false}}" />
      </w-layout-header>
      <w-layout-content>
        <!-- 个人信息卡片 -->
        <view class="profile-card">
          <view class="profile-top">
            <w-badge value="{{noticeCount}}" dot>
              <w-avatar src="https://picsum.photos/seed/admin/200/200" size="large" />
            </w-badge>
            <view class="profile-info">
              <view class="profile-name">运营管理员</view>
              <view class="profile-role">超级管理员 · 全国门店</view>
            </view>
          </view>
          <view class="profile-stats">
            <view class="profile-stat">
              <w-number-animation class="profile-stat__value" value="{{profileStats.totalActivities}}" />
              <view class="profile-stat__label">活动总数</view>
            </view>
            <view class="profile-stat profile-stat--divider">
              <w-number-animation class="profile-stat__value" value="{{profileStats.activeCount}}" />
              <view class="profile-stat__label">进行中</view>
            </view>
            <view class="profile-stat profile-stat--divider">
              <w-number-animation class="profile-stat__value" value="{{profileStats.storeCount}}" />
              <view class="profile-stat__label">管理门店</view>
            </view>
          </view>
        </view>

        <w-divider />

        <!-- 外观设置 -->
        <view class="section-title">外观</view>
        <w-list>
          <w-list-item>
            <text>深色模式</text>
            <w-switch
              slot="suffix"
              checked="{{themeMode === 'dark'}}"
              bind:update:checked="onThemeModeChange"
            />
          </w-list-item>
        </w-list>

        <!-- 主题色 -->
        <view class="section-title">主题色</view>
        <view class="preset-colors">
          <view
            wx:for="{{presetColors}}"
            wx:key="value"
            class="color-dot {{primaryColor === item.value ? 'color-dot--active' : ''}}"
            style="background: {{item.value}};"
            data-color="{{item.value}}"
            bind:tap="onPresetColorTap"
          >
            <view
              wx:if="{{primaryColor === item.value}}"
              class="iconfont icon-check color-dot__check"
            ></view>
          </view>
        </view>

        <view class="color-picker-wrap">
          <view class="color-picker-label">自定义颜色</view>
          <w-color-picker value="{{primaryColor}}" bind:update:value="onColorChange" />
        </view>

        <view class="reset-btn-wrap">
          <w-button size="small" bind:tap="onResetTheme">恢复默认主题</w-button>
        </view>

        <w-divider />

        <!-- 主题预览 -->
        <view class="section-title">主题预览</view>
        <view class="preview-area">
          <view class="preview-row">
            <w-button type="primary" size="small">主要</w-button>
            <w-button type="default" size="small">默认</w-button>
            <w-button type="warning" size="small">警告</w-button>
            <w-button type="danger" size="small">危险</w-button>
          </view>
          <view class="preview-row">
            <w-tag type="success">进行中</w-tag>
            <w-tag type="warning">草稿</w-tag>
            <w-tag type="error">已暂停</w-tag>
            <w-tag type="default">已结束</w-tag>
          </view>
          <view class="preview-row preview-row--between">
            <view class="preview-label">评分</view>
            <w-rate value="{{previewRating}}" bind:update:value="onPreviewRatingChange" />
          </view>
          <view class="preview-row preview-row--between">
            <view class="preview-label">开关</view>
            <w-switch
              checked="{{previewSwitchChecked}}"
              bind:update:checked="onPreviewSwitchChange"
            />
          </view>
        </view>

        <w-divider />

        <!-- 功能 -->
        <view class="section-title">功能</view>
        <w-list>
          <w-list-item>
            <text>消息通知</text>
            <view slot="suffix" class="list-arrow iconfont icon-right"></view>
          </w-list-item>
          <w-list-item>
            <text>数据同步</text>
            <view slot="suffix" class="list-arrow iconfont icon-right"></view>
          </w-list-item>
          <w-list-item>
            <text>导出报表</text>
            <view slot="suffix" class="list-arrow iconfont icon-right"></view>
          </w-list-item>
          <w-list-item>
            <text>帮助与反馈</text>
            <view slot="suffix" class="list-arrow iconfont icon-right"></view>
          </w-list-item>
        </w-list>

        <w-divider />

        <!-- 关于 -->
        <view class="section-title">关于</view>
        <w-list>
          <w-list-item>
            <text>版本</text>
            <view slot="suffix" class="list-extra">v1.0.0</view>
          </w-list-item>
          <w-list-item>
            <text>组件库</text>
            <view slot="suffix" class="list-extra">wedux-ui</view>
          </w-list-item>
        </w-list>

        <view class="bottom-spacer"></view>
      </w-layout-content>
    </w-layout>
  </w-theme-provider>
</view>
