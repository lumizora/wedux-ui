<view
  class="w-radio-button {{_checked ? 'w-radio-button--checked' : ''}} {{(disabled || _groupDisabled) ? 'w-radio-button--disabled' : ''}} w-radio-button--size-{{_groupSize || 'medium'}} {{round ? 'w-radio-button--round' : ''}}"
  hover-class="none"
  bindtap="handleTap"
>
  <text wx:if="{{label}}">{{label}}</text>
  <slot wx:else></slot>
</view>
