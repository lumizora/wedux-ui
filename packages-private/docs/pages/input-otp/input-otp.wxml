<div class="demo-page">
  <scroll-view scroll-y enhanced="{{true}}" show-scrollbar="{{false}}" class="demo-scroll">
    <view class="demo-content">
      <view class="comp-header">
        <view class="comp-header__tag">input-otp</view>
        <view class="comp-header__desc">一次性验证码输入组件，支持自动跳转、掩码、多种尺寸。</view>
      </view>

      <!-- Props -->
      <view class="section">
        <view class="section__title">Props</view>
        <view class="prop-row" wx:for="{{props}}" wx:key="name">
          <view class="prop-row__meta">
            <text class="prop-row__name">{{item.name}}</text>
            <text class="prop-row__type">{{item.type}}</text>
            <text class="prop-row__default">{{item.default}}</text>
          </view>
          <view class="prop-row__desc">{{item.desc}}</view>
        </view>
      </view>

      <!-- Basic -->
      <view class="section">
        <view class="section__title">基础</view>
        <w-input-otp
          value="{{basicVal}}"
          placeholder="-"
          bind:update:value="onBasicChange"
          bind:finish="onFinish"
        />
        <view wx:if="{{finishResult}}" class="section__desc">{{finishResult}}</view>
      </view>

      <!-- Text -->
      <view class="section">
        <view class="section__title">Text</view>
        <w-input-otp
          value="{{textVal}}"
          placeholder="-"
          bind:update:value="onTextChange"
          type="text"
        />
      </view>

      <!-- 4 digits -->
      <view class="section">
        <view class="section__title">4 位</view>
        <w-input-otp value="{{fourVal}}" length="{{4}}" bind:update:value="onFourChange" />
      </view>

      <!-- Mask -->
      <view class="section">
        <view class="section__title">掩码</view>
        <w-input-otp value="{{maskVal}}" mask bind:update:value="onMaskChange" />
      </view>

      <!-- Size -->
      <view class="section">
        <view class="section__title">尺寸</view>
        <w-input-otp length="{{4}}" size="small" placeholder="-" />
        <w-input-otp length="{{4}}" size="medium" placeholder="-" />
        <w-input-otp length="{{4}}" size="large" placeholder="-" />
      </view>

      <!-- Status -->
      <view class="section">
        <view class="section__title">状态</view>
        <w-input-otp length="{{4}}" status="error" />
        <w-input-otp length="{{4}}" status="warning" />
        <w-input-otp length="{{4}}" disabled />
      </view>
    </view>
  </scroll-view>
</div>
