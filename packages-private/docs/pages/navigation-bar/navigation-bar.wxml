<view style="height: 100vh">
  <w-layout>
    <w-layout-header position="static">
      <w-navigation-bar title="Navigation Bar" />
    </w-layout-header>
    <w-layout-content>
      <scroll-view scroll-y enhanced="{{true}}" show-scrollbar="{{false}}" class="demo-scroll">
        <view class="demo-content">
          <view class="comp-header">
            <view class="comp-header__tag">navigation-bar</view>
            <view class="comp-header__desc">
              自定义导航栏，替代原生导航栏，自动适配状态栏高度。
            </view>
          </view>

          <view class="section">
            <view class="section__title">Props</view>
            <view class="prop-row" wx:for="{{props}}" wx:key="name">
              <view class="prop-row__meta">
                <text class="prop-row__name">{{item.name}}</text>
                <text class="prop-row__type">{{item.type}}</text>
                <text class="prop-row__default">{{item.default}}</text>
              </view>
              <view class="prop-row__desc">{{item.desc}}</view>
            </view>
          </view>

          <view class="section">
            <view class="section__title">Slots</view>
            <view class="prop-row">
              <view class="prop-row__meta">
                <text class="prop-row__name">back</text>
              </view>
              <view class="prop-row__desc">自定义返回按钮区域内容（需设置 useBackSlot）</view>
            </view>
            <view class="prop-row">
              <view class="prop-row__meta">
                <text class="prop-row__name">title</text>
              </view>
              <view class="prop-row__desc">自定义标题区域内容（需设置 useTitleSlot）</view>
            </view>
            <view class="prop-row">
              <view class="prop-row__meta">
                <text class="prop-row__name">content</text>
              </view>
              <view class="prop-row__desc">
                自定义整个内容区域，占据胶囊按钮左侧全部空间（需设置 useContentSlot）
              </view>
            </view>
          </view>

          <view class="section">
            <view class="section__title">基本用法</view>
            <view class="demo-note">
              页面 JSON 中需设置 "navigationStyle": "custom" 以隐藏原生导航栏。
            </view>
          </view>

          <view class="section">
            <view class="section__title">自定义标题插槽</view>
            <view class="demo-navbar-wrap">
              <w-navigation-bar useTitleSlot>
                <view slot="title" class="demo-custom-title">
                  <text>自定义标题</text>
                  <view class="demo-badge">NEW</view>
                </view>
              </w-navigation-bar>
            </view>
          </view>

          <view class="section">
            <view class="section__title">自定义内容插槽（搜索栏）</view>
            <view class="demo-navbar-wrap">
              <w-navigation-bar useContentSlot back="{{false}}">
                <view slot="content" class="demo-search-bar">
                  <w-input
                    value="{{val}}"
                    placeholder="搜索"
                    round
                    bind:update:value="onInputChange"
                  />
                </view>
              </w-navigation-bar>
            </view>
          </view>

          <view class="section">
            <view class="section__title">阻止默认返回</view>
            <view class="demo-navbar-wrap">
              <w-navigation-bar title="拦截返回" preventBack bind:back="onCustomBack" />
            </view>
            <view class="demo-note">
              设置 preventBack 后，点击返回按钮仅触发 back 事件，不会自动调用 wx.navigateBack()。
            </view>
          </view>
        </view>
      </scroll-view>
    </w-layout-content>
  </w-layout>
</view>
