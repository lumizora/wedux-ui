<div class="demo-page">
  <scroll-view scroll-y enhanced="{{true}}" show-scrollbar="{{false}}" class="demo-scroll">
    <view class="demo-content">
      <view class="comp-header">
        <view class="comp-header__tag">highlight</view>
        <view class="comp-header__desc">高亮文本，根据关键词自动高亮匹配部分。</view>
      </view>

      <view class="section">
        <view class="section__title">Props</view>
        <view class="prop-row" wx:for="{{props}}" wx:key="name">
          <view class="prop-row__meta">
            <text class="prop-row__name">{{item.name}}</text>
            <text class="prop-row__type">{{item.type}}</text>
            <text class="prop-row__default">{{item.default}}</text>
          </view>
          <view class="prop-row__desc">{{item.desc}}</view>
        </view>
      </view>

      <view class="section">
        <view class="section__title">基础用法</view>
        <view class="section__desc">高亮关键词：quick, fox, dog</view>
        <w-highlight text="{{basicText}}" patterns="{{basicPatterns}}" />
      </view>

      <view class="section">
        <view class="section__title">区分大小写</view>
        <view class="section__desc">仅匹配首字母大写的 "Vue"</view>
        <w-highlight text="{{caseText}}" patterns="{{caseSensitivePatterns}}" case-sensitive />
      </view>

      <view class="section">
        <view class="section__title">中文高亮</view>
        <w-highlight text="{{multiText}}" patterns="{{multiPatterns}}" />
      </view>

      <view class="section">
        <view class="section__title">自定义样式</view>
        <w-highlight
          text="{{customText}}"
          patterns="{{customPatterns}}"
          highlight-style="color: #ffffff; background: var(--color-brand); padding: 0 4rpx; border-radius: 4rpx;"
        />
      </view>
    </view>
  </scroll-view>
</div>
