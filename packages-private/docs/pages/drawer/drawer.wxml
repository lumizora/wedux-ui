<div class="demo-page">
  <scroll-view scroll-y enhanced="{{true}}" show-scrollbar="{{false}}" class="demo-scroll">
    <view class="demo-content">
      <view class="comp-header">
        <view class="comp-header__tag">drawer</view>
        <view class="comp-header__desc">抽屉组件，从屏幕边缘滑出的面板，支持四个方向。</view>
      </view>

      <view class="section">
        <view class="section__title">Props</view>
        <view class="prop-row" wx:for="{{props}}" wx:key="name">
          <view class="prop-row__meta">
            <text class="prop-row__name">{{item.name}}</text>
            <text class="prop-row__type">{{item.type}}</text>
            <text class="prop-row__default">{{item.default}}</text>
          </view>
          <view class="prop-row__desc">{{item.desc}}</view>
        </view>
      </view>

      <view class="section">
        <view class="section__title">底部抽屉（圆角）</view>
        <w-button bindtap="onToggle1">打开底部抽屉</w-button>
        <w-drawer show="{{show1}}" placement="bottom" round bind:update:show="onClose1">
          <view class="drawer-demo-content">
            <view class="drawer-demo-text">底部抽屉内容</view>
          </view>
          <w-button slot="footer" type="primary" block bindtap="onClose1">关闭</w-button>
        </w-drawer>
      </view>

      <view class="section">
        <view class="section__title">右侧抽屉（带标题）</view>
        <w-button bindtap="onToggle2">打开右侧抽屉</w-button>
        <w-drawer
          show="{{show2}}"
          placement="right"
          width="70%"
          title="标题"
          closable
          bind:update:show="onClose2"
        >
          <view class="drawer-demo-content">
            <view class="drawer-demo-text">右侧抽屉内容</view>
          </view>
        </w-drawer>
      </view>

      <view class="section">
        <view class="section__title">左侧抽屉</view>
        <w-button bindtap="onToggle3">打开左侧抽屉</w-button>
        <w-drawer
          show="{{show3}}"
          placement="left"
          width="60%"
          title="菜单"
          closable
          bind:update:show="onClose3"
        >
          <view class="drawer-demo-content">
            <view class="drawer-demo-text">左侧抽屉内容</view>
          </view>
        </w-drawer>
      </view>

      <view class="section">
        <view class="section__title">顶部抽屉</view>
        <w-button bindtap="onToggle4">打开顶部抽屉</w-button>
        <w-drawer show="{{show4}}" placement="top" height="40%" round bind:update:show="onClose4">
          <view class="drawer-demo-content">
            <view class="drawer-demo-text">顶部抽屉内容</view>
            <w-button type="primary" block bindtap="onClose4">关闭</w-button>
          </view>
        </w-drawer>
      </view>
    </view>
  </scroll-view>
</div>
