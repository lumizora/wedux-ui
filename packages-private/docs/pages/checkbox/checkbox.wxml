<div class="demo-page">
  <scroll-view scroll-y enhanced="{{true}}" show-scrollbar="{{false}}" class="demo-scroll">
    <view class="demo-content">
      <view class="comp-header">
        <view class="comp-header__tag">checkbox-group / checkbox</view>
        <view class="comp-header__desc">多选组件，用于在一组选项中选择多个。</view>
      </view>

      <view class="section">
        <view class="section__title">CheckboxGroup Props</view>
        <view class="prop-row" wx:for="{{groupProps}}" wx:key="name">
          <view class="prop-row__meta">
            <text class="prop-row__name">{{item.name}}</text>
            <text class="prop-row__type">{{item.type}}</text>
            <text class="prop-row__default">{{item.default}}</text>
          </view>
          <view class="prop-row__desc">{{item.desc}}</view>
        </view>
      </view>

      <view class="section">
        <view class="section__title">Checkbox Props</view>
        <view class="prop-row" wx:for="{{checkboxProps}}" wx:key="name">
          <view class="prop-row__meta">
            <text class="prop-row__name">{{item.name}}</text>
            <text class="prop-row__type">{{item.type}}</text>
            <text class="prop-row__default">{{item.default}}</text>
          </view>
          <view class="prop-row__desc">{{item.desc}}</view>
        </view>
      </view>

      <view class="section">
        <view class="section__title">基础</view>
        <w-checkbox-group value="{{val1}}" bind:update:value="onChange1">
          <w-checkbox value="apple" label="苹果" />
          <w-checkbox value="banana" label="香蕉" />
          <w-checkbox value="orange" label="橙子" />
        </w-checkbox-group>
        <view class="demo-hint">当前选中：{{val1}}</view>
      </view>

      <view class="section">
        <view class="section__title">纵向排列</view>
        <w-checkbox-group value="{{val2}}" vertical bind:update:value="onChange2">
          <w-checkbox value="opt1" label="选项一" />
          <w-checkbox value="opt2" label="选项二" />
          <w-checkbox value="opt3" label="选项三" />
        </w-checkbox-group>
      </view>

      <view class="section">
        <view class="section__title">最多选 2 个</view>
        <w-checkbox-group value="{{val3}}" max="{{2}}" bind:update:value="onChange3">
          <w-checkbox value="A" label="选项 A" />
          <w-checkbox value="B" label="选项 B" />
          <w-checkbox value="C" label="选项 C" />
          <w-checkbox value="D" label="选项 D" />
        </w-checkbox-group>
      </view>

      <view class="section">
        <view class="section__title">禁用 + 不确定状态</view>
        <w-checkbox-group value="{{['x']}}">
          <w-checkbox value="x" label="选中" />
          <w-checkbox value="y" label="禁用" disabled />
          <w-checkbox value="z" label="不确定" indeterminate />
        </w-checkbox-group>
      </view>

      <view class="section">
        <view class="section__title">整组禁用</view>
        <w-checkbox-group value="{{['a']}}" disabled>
          <w-checkbox value="a" label="选项 A" />
          <w-checkbox value="b" label="选项 B" />
        </w-checkbox-group>
      </view>
    </view>
  </scroll-view>
</div>
