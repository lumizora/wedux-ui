<view class="page">
  <w-theme-provider theme="{{theme}}">
    <w-layout>
      <w-layout-header position="static">
        <w-navigation-bar title="分享活动" />
      </w-layout-header>
      <w-layout-content>
        <scroll-view scroll-y enhanced="{{true}}" show-scrollbar="{{false}}" class="scroll-view">
          <block wx:if="{{activity}}">
            <!-- 分享卡片预览 -->
            <view class="share-card">
              <view class="share-card__header">
                <w-image
                  class="share-card__cover"
                  src="{{activity.coverImage}}"
                  mode="aspectFill"
                  radius="{{12}}"
                  width="{{180}}"
                  height="{{120}}"
                />
                <view class="share-card__info">
                  <view class="share-card__title">{{activity.title}}</view>
                  <view class="share-card__meta">
                    <w-tag type="{{activity.statusType}}" size="small"
                      >{{activity.statusLabel}}</w-tag
                    >
                  </view>
                  <view class="share-card__time">{{activity.startTime}}</view>
                  <view class="share-card__location">
                    <view class="iconfont icon-location"></view>
                    <text>{{activity.location}}</text>
                  </view>
                </view>
              </view>
              <w-divider style="margin: 0" />
              <view class="share-card__desc">{{activity.description}}</view>
            </view>

            <!-- 二维码区 -->
            <view class="qr-section">
              <view class="qr-label">扫码参与活动</view>
              <view class="qr-wrap">
                <w-qr-code value="{{qrValue}}" size="{{400}}" />
              </view>
              <view class="qr-hint">微信扫一扫，立即参与</view>
              <view class="qr-link" bind:tap="onCopyLink">
                <view class="iconfont icon-copy qr-link__icon"></view>
                <text class="qr-link__text">复制活动链接</text>
              </view>
            </view>

            <w-divider />

            <!-- 操作按钮 -->
            <view class="actions">
              <w-button type="default" loading="{{saving}}" bind:tap="onSave" class="action-btn">
                <view class="iconfont icon-download"></view>
                <text>保存图片</text>
              </w-button>
              <w-button type="primary" loading="{{sharing}}" bind:tap="onShare" class="action-btn">
                <view class="iconfont icon-share"></view>
                <text>转发给朋友</text>
              </w-button>
            </view>

            <!-- 参与数据 -->
            <view class="stats-row">
              <view class="stats-item">
                <view class="stats-item__num">{{activity.actualCount}}</view>
                <view class="stats-item__label">已参与</view>
              </view>
              <view class="stats-item">
                <view class="stats-item__num">{{activity.targetCount}}</view>
                <view class="stats-item__label">目标人数</view>
              </view>
              <view class="stats-item">
                <view class="stats-item__num">¥{{activity.budget}}</view>
                <view class="stats-item__label">活动预算</view>
              </view>
            </view>
          </block>

          <view class="bottom-spacer"></view>
        </scroll-view>
      </w-layout-content>
    </w-layout>
  </w-theme-provider>
</view>
