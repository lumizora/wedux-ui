<div class="demo-page">
  <scroll-view scroll-y enhanced="{{true}}" show-scrollbar="{{false}}" class="demo-scroll">
    <view class="demo-content">
      <view class="comp-header">
        <view class="comp-header__tag">button-group</view>
        <view class="comp-header__desc">
          将多个按钮合并为一组，自动处理相邻按钮的圆角裁剪和边框折叠。
        </view>
      </view>

      <view class="section">
        <view class="section__title">Props</view>
        <view class="prop-row" wx:for="{{props}}" wx:key="name">
          <view class="prop-row__meta">
            <text class="prop-row__name">{{item.name}}</text>
            <text class="prop-row__type">{{item.type}}</text>
            <text class="prop-row__default">{{item.default}}</text>
          </view>
          <view class="prop-row__desc">{{item.desc}}</view>
        </view>
      </view>

      <view class="section">
        <view class="section__title">横向 horizontal</view>
        <w-flex vertical size="medium">
          <w-button-group>
            <w-button type="default">Left</w-button>
            <w-button type="default">Center</w-button>
            <w-button type="default">Right</w-button>
          </w-button-group>
          <w-button-group>
            <w-button type="default">Left</w-button>
            <w-button type="default">Center</w-button>
            <w-button type="default">Right</w-button>
          </w-button-group>
          <w-button-group>
            <w-button type="primary">Yes</w-button>
            <w-button type="error">No</w-button>
          </w-button-group>
        </w-flex>
      </view>

      <view class="section">
        <view class="section__title">纵向 vertical</view>
        <w-button-group vertical>
          <w-button type="default">Top</w-button>
          <w-button type="default">Middle</w-button>
          <w-button type="default">Bottom</w-button>
        </w-button-group>
      </view>

      <view class="section">
        <view class="section__title">统一尺寸 size</view>
        <w-button-group size="small">
          <w-button type="default">A</w-button>
          <w-button type="default">B</w-button>
          <w-button type="default">C</w-button>
          <w-button type="default">D</w-button>
        </w-button-group>
      </view>
    </view>
  </scroll-view>
</div>
