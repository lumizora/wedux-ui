<div class="demo-page">
  <scroll-view scroll-y enhanced="{{true}}" show-scrollbar="{{false}}" class="demo-scroll">
    <view class="demo-content">
      <view class="comp-header">
        <view class="comp-header__tag">stepper</view>
        <view class="comp-header__desc">步进器，用于数值的增减操作。</view>
      </view>

      <view class="section">
        <view class="section__title">Props</view>
        <view class="prop-row" wx:for="{{props}}" wx:key="name">
          <view class="prop-row__meta">
            <text class="prop-row__name">{{item.name}}</text>
            <text class="prop-row__type">{{item.type}}</text>
            <text class="prop-row__default">{{item.default}}</text>
          </view>
          <view class="prop-row__desc">{{item.desc}}</view>
        </view>
      </view>

      <view class="section">
        <view class="section__title">基础</view>
        <w-stepper value="{{val1}}" bind:update:value="onChange1" />
      </view>

      <view class="section">
        <view class="section__title">步长与范围</view>
        <w-stepper
          value="{{val2}}"
          min="{{0}}"
          max="{{10}}"
          step="{{2}}"
          bind:update:value="onChange2"
          bind:overlimit="onOverlimit"
        />
      </view>

      <view class="section">
        <view class="section__title">小数步长</view>
        <w-stepper
          value="{{val3}}"
          min="{{0}}"
          max="{{5}}"
          step="{{0.1}}"
          decimalLength="{{1}}"
          bind:update:value="onChange3"
        />
      </view>

      <view class="section">
        <view class="section__title">尺寸</view>
        <w-flex align="center" size="small">
          <w-stepper value="{{val4}}" bind:update:value="onChange4" />
          <w-stepper value="{{val5}}" size="small" bind:update:value="onChange5" />
        </w-flex>
      </view>

      <view class="section">
        <view class="section__title">禁用</view>
        <w-stepper value="{{5}}" disabled />
      </view>
    </view>
  </scroll-view>
</div>
