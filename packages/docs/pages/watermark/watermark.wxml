<div class="demo-page">
  <scroll-view scroll-y enhanced="{{true}}" show-scrollbar="{{false}}" class="demo-scroll">
    <view class="demo-content">
      <view class="comp-header">
        <view class="comp-header__tag">watermark</view>
        <view class="comp-header__desc">水印组件，用于在内容上覆盖水印标识。</view>
      </view>

      <view class="section">
        <view class="section__title">Props</view>
        <view class="prop-row" wx:for="{{props}}" wx:key="name">
          <view class="prop-row__meta">
            <text class="prop-row__name">{{item.name}}</text>
            <text class="prop-row__type">{{item.type}}</text>
            <text class="prop-row__default">{{item.default}}</text>
          </view>
          <view class="prop-row__desc">{{item.desc}}</view>
        </view>
      </view>

      <view class="section">
        <view class="section__title">基础文字水印</view>
        <w-watermark content="WeduxUI Watermark" style="height: 400rpx; display: block">
          <view class="demo-box">
            <text>这里是被水印覆盖的内容区域。水印会以平铺方式重复显示在整个容器中。</text>
          </view>
        </w-watermark>
      </view>

      <view class="section">
        <view class="section__title">多行文字</view>
        <w-watermark
          content="{{'WeduxUI\\nWatermark'}}"
          height="{{80}}"
          style="height: 400rpx; display: block"
        >
          <view class="demo-box">
            <text>支持使用换行符来显示多行水印文字。</text>
          </view>
        </w-watermark>
      </view>

      <view class="section">
        <view class="section__title">交叉排列</view>
        <w-watermark content="WeduxUI" cross style="height: 400rpx; display: block">
          <view class="demo-box">
            <text>交叉排列的水印，相邻行错开显示，覆盖更均匀。</text>
          </view>
        </w-watermark>
      </view>

      <view class="section">
        <view class="section__title">自定义样式</view>
        <w-watermark
          content="Confidential"
          font-color="rgba(255, 0, 0, 0.12)"
          font-size="{{18}}"
          font-weight="bold"
          rotate="{{-30}}"
          width="{{160}}"
          height="{{80}}"
          style="height: 400rpx; display: block"
        >
          <view class="demo-box">
            <text>自定义字号、颜色、粗细和角度的水印。</text>
          </view>
        </w-watermark>
      </view>

      <view class="section">
        <view class="section__title">图片水印</view>
        <w-watermark
          image="https://picsum.photos/40/40"
          image-width="{{40}}"
          image-height="{{40}}"
          image-opacity="{{0.15}}"
          width="{{80}}"
          height="{{80}}"
          rotate="{{0}}"
          style="height: 400rpx; display: block"
        >
          <view class="demo-box">
            <text>使用图片作为水印内容。</text>
          </view>
        </w-watermark>
      </view>
    </view>
  </scroll-view>
</div>
